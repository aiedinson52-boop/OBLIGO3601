{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/",
            "destination": "/asistente.html"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/asistente.html"
        }
    ],
    "buildCommand": "npm run build",
    "outputDirectory": "dist"
}